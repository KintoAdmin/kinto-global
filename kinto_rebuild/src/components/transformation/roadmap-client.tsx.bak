// Kinto Global — Interactive Transformation Roadmap Client
// Consolidates all 5 diagnostic modules into one project implementation tracker
'use client';

import { useState, useMemo, useEffect, useTransition, useCallback } from 'react';

// ── Types ─────────────────────────────────────────────────────────────────────
type RoadmapItem = {
  roadmap_fact_id?: string;
  roadmap_instance_id?: string;
  initiative_title: string;
  initiative_description?: string;
  phase_code: string;
  phase_name?: string;
  owner_role?: string;
  business_outcome?: string;
  review_frequency?: string;
  source_module_id?: string;
  module_code?: string;
  status?: string;
  progress_pct?: number;
  execution_notes?: string;
  last_reviewed_at?: string;
  priority_rank?: number;
  automation_opportunity?: string;
};

type ModuleScore = {
  module_code: string;
  module_name: string;
  score_pct: number;
  completion_pct: number;
};

type Props = {
  assessmentId: string;
  initialItems: RoadmapItem[];
  moduleScores: ModuleScore[];
};

// ── Constants ─────────────────────────────────────────────────────────────────
const PHASES = [
  { code: 'P1', name: 'Stabilise & Protect',            pill: 'phase-1-pill', description: 'Fix critical gaps, establish ownership, protect revenue' },
  { code: 'P2', name: 'Standardise & Strengthen',       pill: 'phase-2-pill', description: 'Build consistent processes, improve data quality, deepen controls' },
  { code: 'P3', name: 'Optimise, Automate & AI-Enable', pill: 'phase-3-pill', description: 'Scale operations, automate repeatable work, deploy AI capabilities' },
];

const MODULE_META: Record<string, { label: string; icon: string; color: string }> = {
  'MOD-OPS':  { label: 'Operational Audit', icon: '🔍', color: '#1ABCB0' },
  'MOD-LEAK': { label: 'Revenue Leakage',   icon: '💰', color: '#EF4444' },
  'MOD-DATA': { label: 'Data Foundation',   icon: '🗄️', color: '#3B82F6' },
  'MOD-AIR':  { label: 'AI Readiness',      icon: '🤖', color: '#8B5CF6' },
  'MOD-AIUC': { label: 'AI Use Cases',      icon: '⚡', color: '#F59E0B' },
  OPS:        { label: 'Operational Audit', icon: '🔍', color: '#1ABCB0' },
  LEAK:       { label: 'Revenue Leakage',   icon: '💰', color: '#EF4444' },
  DATA:       { label: 'Data Foundation',   icon: '🗄️', color: '#3B82F6' },
  AIR:        { label: 'AI Readiness',      icon: '🤖', color: '#8B5CF6' },
  AIUC:       { label: 'AI Use Cases',      icon: '⚡', color: '#F59E0B' },
};

const STATUSES = ['NOT_STARTED', 'IN_PROGRESS', 'ON_HOLD', 'BLOCKED', 'COMPLETE'] as const;
type StatusValue = (typeof STATUSES)[number];

const STATUS_LABELS: Record<string, string> = {
  NOT_STARTED: 'Not Started', IN_PROGRESS: 'In Progress',
  ON_HOLD: 'On Hold', BLOCKED: 'Blocked', COMPLETE: 'Complete',
};
const STATUS_BADGE: Record<string, string> = {
  NOT_STARTED: 'badge-muted', IN_PROGRESS: 'badge-info',
  ON_HOLD: 'badge-warn', BLOCKED: 'badge-danger', COMPLETE: 'badge-success',
};

function modMeta(id?: string | null) {
  if (!id) return { label: 'Multi-module', icon: '📊', color: '#94A3B8' };
  return MODULE_META[id] ?? { label: id, icon: '📊', color: '#94A3B8' };
}

function normStatus(s?: string | null): StatusValue {
  const v = String(s || '').toUpperCase().replace(/[\s-]/g, '_') as StatusValue;
  return STATUSES.includes(v) ? v : 'NOT_STARTED';
}

function itemId(item: RoadmapItem): string {
  return item.roadmap_fact_id || item.roadmap_instance_id || item.initiative_title;
}

// ── Roadmap Card ──────────────────────────────────────────────────────────────
function RoadmapCard({
  item, saving, onSave,
}: {
  item: RoadmapItem;
  saving: string | null;
  onSave: (id: string, patch: { status?: string; progressPct?: number; executionNotes?: string }) => Promise<void>;
}) {
  const id      = itemId(item);
  const isBusy  = saving === id;
  const status  = normStatus(item.status);
  const pct     = item.progress_pct ?? (status === 'COMPLETE' ? 100 : 0);
  const mod     = modMeta(item.source_module_id || item.module_code);
  const [open, setOpen]         = useState(false);
  const [noteDraft, setNote]    = useState(item.execution_notes || '');
  const [pctDraft,  setPctDraft] = useState(pct);

  // Keep local draft in sync when parent updates item after save
  // eslint-disable-next-line react-hooks/exhaustive-deps
  useEffect(() => { setPctDraft(item.progress_pct ?? (normStatus(item.status) === 'COMPLETE' ? 100 : 0)); }, [item.progress_pct, item.status]);
  useEffect(() => { setNote(item.execution_notes || ''); }, [item.execution_notes]);

  async function handleStatus(next: string) {
    const autoPct = next === 'COMPLETE' ? 100 : next === 'NOT_STARTED' ? 0 : undefined;
    await onSave(id, { status: next, ...(autoPct !== undefined ? { progressPct: autoPct } : {}) });
  }

  return (
    <div style={{
      background: 'var(--surface)',
      border: `1px solid ${status === 'COMPLETE' ? 'var(--success-border)' : status === 'BLOCKED' ? 'var(--danger-border)' : 'var(--line)'}`,
      borderLeft: `3px solid ${mod.color}`,
      borderRadius: 'var(--radius)',
      padding: '0.85rem 1rem',
      opacity: isBusy ? 0.75 : 1,
      transition: 'opacity 0.15s',
    }}>
      {/* Top row */}
      <div style={{ display: 'flex', alignItems: 'flex-start', gap: '0.75rem', marginBottom: '0.5rem' }}>
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: '0.4rem', flexWrap: 'wrap', marginBottom: '0.3rem' }}>
            <span style={{ fontSize: '0.72rem', fontWeight: 700, color: mod.color, flexShrink: 0 }}>
              {mod.icon} {mod.label}
            </span>
            {item.owner_role && (
              <span className="badge badge-muted" style={{ fontSize: '0.65rem' }}>👤 {item.owner_role}</span>
            )}
            {item.review_frequency && (
              <span className="badge badge-muted" style={{ fontSize: '0.65rem' }}>🔄 {item.review_frequency}</span>
            )}
            {String(item.automation_opportunity || '').toLowerCase().includes('auto') && (
              <span className="badge badge-info" style={{ fontSize: '0.65rem' }}>⚡ Automation</span>
            )}
          </div>
          <p style={{ fontWeight: 600, fontSize: '0.9rem', margin: 0, lineHeight: 1.35 }}>
            {item.initiative_title}
          </p>
          {item.business_outcome && (
            <p style={{ fontSize: '0.78rem', color: 'var(--muted-2)', margin: '0.2rem 0 0', lineHeight: 1.3 }}>
              {item.business_outcome}
            </p>
          )}
        </div>

        {/* Status + saving indicator */}
        <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'flex-end', gap: '0.3rem', flexShrink: 0 }}>
          <select
            value={status}
            disabled={isBusy}
            onChange={e => void handleStatus(e.target.value)}
            className={`badge ${STATUS_BADGE[status]}`}
            style={{
              cursor: 'pointer', border: 'none', fontWeight: 600, fontSize: '0.72rem',
              padding: '0.2rem 0.5rem', borderRadius: 999, appearance: 'none',
              textAlign: 'center', minWidth: 92, background: undefined,
            }}
          >
            {STATUSES.map(s => <option key={s} value={s}>{STATUS_LABELS[s]}</option>)}
          </select>
          {isBusy && (
            <span style={{ fontSize: '0.65rem', color: 'var(--brand-dark)', display: 'flex', alignItems: 'center', gap: 3 }}>
              <span style={{ display: 'inline-block', width: 8, height: 8, borderRadius: '50%', border: '1.5px solid var(--brand)', borderTopColor: 'transparent', animation: 'spin 0.7s linear infinite' }} />
              Saving
            </span>
          )}
        </div>
      </div>

      {/* Progress bar */}
      <div style={{ marginBottom: '0.45rem' }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', fontSize: '0.7rem', color: 'var(--muted-2)', marginBottom: '0.2rem' }}>
          <span>Progress</span>
          <span style={{ fontWeight: 700, color: pct === 100 ? 'var(--brand-dark)' : 'inherit' }}>{pct}%</span>
        </div>
        <div className="progress-bar-shell" style={{ height: 6 }}>
          <div
            className={`progress-bar-fill${pct < 40 ? ' danger' : pct < 70 ? ' warn' : ''}`}
            style={{ width: `${pct}%`, transition: 'width 0.3s ease' }}
          />
        </div>
      </div>

      {/* Execution notes preview */}
      {item.execution_notes && !open && (
        <p style={{ fontSize: '0.75rem', color: 'var(--muted-2)', margin: '0.3rem 0 0.4rem', fontStyle: 'italic', lineHeight: 1.35 }}>
          📝 {item.execution_notes.slice(0, 100)}{item.execution_notes.length > 100 ? '…' : ''}
        </p>
      )}

      {/* Expand toggle */}
      <button
        type="button"
        onClick={() => setOpen(o => !o)}
        style={{ background: 'none', border: 'none', cursor: 'pointer', fontSize: '0.7rem', color: 'var(--muted)', padding: '0.1rem 0', display: 'flex', alignItems: 'center', gap: '0.25rem' }}
      >
        {open ? '▲ Collapse' : '▼ Update progress & notes'}
      </button>

      {/* Expanded edit area */}
      {open && (
        <div style={{ marginTop: '0.65rem', borderTop: '1px solid var(--line)', paddingTop: '0.65rem', display: 'grid', gap: '0.65rem' }}>

          {/* Quick status buttons */}
          <div style={{ display: 'flex', gap: '0.35rem', flexWrap: 'wrap' }}>
            {STATUSES.map(s => (
              <button
                key={s}
                type="button"
                onClick={() => void handleStatus(s)}
                disabled={isBusy}
                className={`badge ${STATUS_BADGE[s]}`}
                style={{
                  cursor: 'pointer', fontWeight: status === s ? 700 : 500,
                  outline: status === s ? '2px solid currentColor' : 'none',
                  outlineOffset: 2, opacity: status === s ? 1 : 0.6,
                }}
              >
                {STATUS_LABELS[s]}
              </button>
            ))}
          </div>

          {/* Progress slider */}
          <div className="field-block">
            <span className="field-label">Progress — {pctDraft}%</span>
            <div style={{ display: 'flex', alignItems: 'center', gap: '0.6rem' }}>
              <input
                type="range" min={0} max={100} step={5}
                value={pctDraft}
                onChange={e => setPctDraft(Number(e.target.value))}
                onMouseUp={() => void onSave(id, { progressPct: pctDraft })}
                onTouchEnd={() => void onSave(id, { progressPct: pctDraft })}
                style={{ flex: 1, accentColor: 'var(--brand)' }}
              />
              <span style={{ fontWeight: 700, minWidth: 40, textAlign: 'right', fontSize: '0.875rem' }}>{pctDraft}%</span>
            </div>
          </div>

          {/* Notes */}
          <div className="field-block">
            <span className="field-label">Execution notes</span>
            <textarea
              className="kinto-textarea"
              rows={3}
              style={{ fontSize: '0.82rem' }}
              value={noteDraft}
              onChange={e => setNote(e.target.value)}
              placeholder="Updates, blockers, decisions, context, next steps…"
              onBlur={() => {
                if (noteDraft !== (item.execution_notes || '')) {
                  void onSave(id, { executionNotes: noteDraft });
                }
              }}
            />
          </div>

          {item.initiative_description && (
            <p className="text-xs muted-2"><strong>Full description:</strong> {item.initiative_description}</p>
          )}
          {item.last_reviewed_at && (
            <p className="text-xs muted-2">
              Last reviewed: {new Date(item.last_reviewed_at).toLocaleDateString('en-ZA', { day: 'numeric', month: 'short', year: 'numeric' })}
            </p>
          )}
        </div>
      )}
    </div>
  );
}

// ── Main Component ────────────────────────────────────────────────────────────
export function RoadmapClient({ assessmentId, initialItems, moduleScores }: Props) {
  const [items, setItems]       = useState<RoadmapItem[]>(initialItems);
  const [saving, setSaving]     = useState<string | null>(null);
  const [error, setError]       = useState<string | null>(null);
  const [filterModule, setFM]   = useState('ALL');
  const [filterStatus, setFS]   = useState('ALL');
  const [filterPhase,  setFP]   = useState('ALL');
  const [searchText,   setSearch] = useState('');
  const [view, setView]         = useState<'board' | 'table'>('board');
  const [, startTransition]     = useTransition();

  // ── Save handler ──────────────────────────────────────────────────────
  async function saveItem(id: string, patch: { status?: string; progressPct?: number; executionNotes?: string }) {
    setSaving(id);
    setError(null);
    // Optimistic
    setItems(prev => prev.map(i =>
      itemId(i) === id
        ? {
            ...i,
            ...('status' in patch         ? { status: patch.status }                    : {}),
            ...('progressPct' in patch     ? { progress_pct: patch.progressPct }         : {}),
            ...('executionNotes' in patch  ? { execution_notes: patch.executionNotes }   : {}),
          }
        : i
    ));
    try {
      const r = await fetch(
        `/api/assessments/${encodeURIComponent(assessmentId)}/roadmap/${encodeURIComponent(id)}`,
        { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(patch) }
      );
      const p = await r.json().catch(() => null);
      if (!r.ok || p?.error) throw new Error(p?.error || `HTTP ${r.status}`);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Save failed — last change may not have persisted');
      setItems(initialItems); // rollback
    } finally {
      startTransition(() => setSaving(null));
    }
  }

  // ── Derived data ──────────────────────────────────────────────────────
  const allModules = useMemo(() => {
    const seen = new Set<string>();
    return items.reduce<Array<{ id: string; label: string; icon: string }>>((acc, item) => {
      const id = item.source_module_id || item.module_code || '';
      if (id && !seen.has(id)) { seen.add(id); const m = modMeta(id); acc.push({ id, label: m.label, icon: m.icon }); }
      return acc;
    }, []);
  }, [items]);

  const filtered = useMemo(() => {
    const s = searchText.trim().toLowerCase();
    return items.filter(item => {
      const mId = item.source_module_id || item.module_code || '';
      if (filterModule !== 'ALL' && mId !== filterModule) return false;
      if (filterStatus !== 'ALL' && normStatus(item.status) !== filterStatus) return false;
      if (filterPhase  !== 'ALL' && (item.phase_code || 'P2') !== filterPhase) return false;
      if (s) {
        const hay = [item.initiative_title, item.owner_role, item.business_outcome, item.execution_notes].join(' ').toLowerCase();
        if (!hay.includes(s)) return false;
      }
      return true;
    });
  }, [items, filterModule, filterStatus, filterPhase, searchText]);

  const byPhase = useMemo(() =>
    PHASES.map(ph => ({ ...ph, items: filtered.filter(i => (i.phase_code || 'P2') === ph.code) })),
    [filtered]
  );

  const stats = useMemo(() => {
    const total    = items.length;
    const complete = items.filter(i => normStatus(i.status) === 'COMPLETE').length;
    const inprog   = items.filter(i => normStatus(i.status) === 'IN_PROGRESS').length;
    const blocked  = items.filter(i => normStatus(i.status) === 'BLOCKED').length;
    const onhold   = items.filter(i => normStatus(i.status) === 'ON_HOLD').length;
    const pct      = total > 0 ? Math.round((complete / total) * 100) : 0;

    // Per-module breakdown
    const byMod: Record<string, { total: number; complete: number; pct: number }> = {};
    for (const item of items) {
      const mId = item.source_module_id || item.module_code || 'UNKNOWN';
      if (!byMod[mId]) byMod[mId] = { total: 0, complete: 0, pct: 0 };
      byMod[mId].total++;
      if (normStatus(item.status) === 'COMPLETE') byMod[mId].complete++;
    }
    for (const mId of Object.keys(byMod)) {
      const m = byMod[mId];
      m.pct = m.total > 0 ? Math.round((m.complete / m.total) * 100) : 0;
    }
    return { total, complete, inprog, blocked, onhold, pct, byMod };
  }, [items]);

  const clearFilters = () => { setFM('ALL'); setFS('ALL'); setFP('ALL'); setSearch(''); };

  // ── Render ────────────────────────────────────────────────────────────
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: '1.25rem' }}>
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>

      {/* Error banner */}
      {error && (
        <div style={{ padding: '0.65rem 1rem', background: 'var(--danger-bg)', border: '1px solid var(--danger-border)', borderRadius: 'var(--radius-sm)', color: 'var(--danger)', fontSize: '0.85rem', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
          <span>⚠ {error}</span>
          <button onClick={() => setError(null)} style={{ background: 'none', border: 'none', cursor: 'pointer', color: 'var(--danger)', fontSize: '1rem', lineHeight: 1 }}>✕</button>
        </div>
      )}

      {/* KPI strip */}
      <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(140px, 1fr))', gap: '0.75rem' }}>
        {[
          { label: 'Total Actions', value: String(stats.total),    sub: 'All phases · all modules' },
          { label: 'Complete',      value: String(stats.complete), sub: `${stats.pct}% done`, accent: stats.pct === 100 },
          { label: 'In Progress',   value: String(stats.inprog),   sub: 'Active now' },
          { label: 'Blocked',       value: String(stats.blocked),  sub: 'Needs attention', danger: stats.blocked > 0 },
          { label: 'On Hold',       value: String(stats.onhold),   sub: 'Paused' },
        ].map(k => (
          <div key={k.label} className={`stat-card${(k as any).accent ? ' stat-card-accent' : ''}`}>
            <div className="stat-card-label">{k.label}</div>
            <div className="stat-card-value" style={{ fontSize: '1.3rem', color: (k as any).danger ? 'var(--danger)' : undefined }}>{k.value}</div>
            <div className="stat-card-sub">{k.sub}</div>
          </div>
        ))}
      </div>

      {/* Overall progress bar */}
      {stats.total > 0 && (
        <div style={{ padding: '0.75rem 1rem', background: 'var(--surface)', border: '1px solid var(--line)', borderRadius: 'var(--radius)' }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '0.4rem', fontSize: '0.85rem' }}>
            <span style={{ fontWeight: 600 }}>Overall Transformation Progress</span>
            <span style={{ fontWeight: 700 }}>{stats.pct}%</span>
          </div>
          <div className="progress-bar-shell" style={{ height: 12 }}>
            <div className="progress-bar-fill" style={{ width: `${stats.pct}%`, transition: 'width 0.4s ease' }} />
          </div>
          <p style={{ fontSize: '0.72rem', color: 'var(--muted-2)', marginTop: '0.35rem' }}>
            {stats.complete} of {stats.total} actions complete
          </p>
        </div>
      )}

      {/* Diagnostic score vs roadmap completion comparison */}
      {moduleScores.length > 0 && stats.total > 0 && (
        <div className="card">
          <div className="card-header">
            <div>
              <h3 className="card-title">Diagnostic Score vs Implementation Progress</h3>
              <p className="card-subtitle">Assessment maturity alongside roadmap execution — the gap shows implementation ahead of current diagnostic baseline</p>
            </div>
          </div>
          <div style={{ display: 'grid', gap: '0' }}>
            {moduleScores.map((m, idx) => {
              const mId      = m.module_code;
              const mod      = modMeta(mId);
              const mIdFull  = `MOD-${mId}`;
              const rd       = stats.byMod[mIdFull] || stats.byMod[mId] || { total: 0, complete: 0, pct: 0 };
              const diagPct  = Math.round(m.score_pct || 0);
              const implPct  = rd.pct;
              const gap      = implPct - diagPct;

              return (
                <div key={mId} style={{ display: 'grid', gridTemplateColumns: '180px 1fr 1fr 70px', gap: '0.85rem', alignItems: 'center', padding: '0.6rem 0', borderBottom: idx < moduleScores.length - 1 ? '1px solid var(--line)' : 'none' }}>
                  <span style={{ fontWeight: 600, fontSize: '0.82rem', display: 'flex', alignItems: 'center', gap: '0.35rem' }}>
                    <span>{mod.icon}</span>{m.module_name}
                  </span>
                  <div>
                    <div style={{ fontSize: '0.68rem', color: 'var(--muted-2)', marginBottom: '0.2rem' }}>Diagnostic score</div>
                    <div style={{ display: 'flex', alignItems: 'center', gap: '0.45rem' }}>
                      <div className="progress-bar-shell" style={{ flex: 1, height: 7 }}>
                        <div className={`progress-bar-fill${diagPct < 40 ? ' danger' : diagPct < 65 ? ' warn' : ''}`} style={{ width: `${diagPct}%` }} />
                      </div>
                      <span style={{ fontWeight: 700, minWidth: 32, fontSize: '0.78rem' }}>{diagPct > 0 ? `${diagPct}%` : '—'}</span>
                    </div>
                  </div>
                  <div>
                    <div style={{ fontSize: '0.68rem', color: 'var(--muted-2)', marginBottom: '0.2rem' }}>
                      Roadmap actions ({rd.complete}/{rd.total})
                    </div>
                    <div style={{ display: 'flex', alignItems: 'center', gap: '0.45rem' }}>
                      <div className="progress-bar-shell" style={{ flex: 1, height: 7 }}>
                        <div className="progress-bar-fill" style={{ width: `${implPct}%`, background: mod.color }} />
                      </div>
                      <span style={{ fontWeight: 700, minWidth: 32, fontSize: '0.78rem' }}>{rd.total > 0 ? `${implPct}%` : '—'}</span>
                    </div>
                  </div>
                  <div style={{ textAlign: 'right' }}>
                    {diagPct > 0 && rd.total > 0 && (
                      <span style={{ fontSize: '0.72rem', fontWeight: 700, color: gap >= 0 ? 'var(--brand-dark)' : 'var(--warn)' }}>
                        {gap > 0 ? `+${gap}%` : gap < 0 ? `${gap}%` : 'Even'}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
          <p style={{ fontSize: '0.7rem', color: 'var(--muted-2)', marginTop: '0.65rem', lineHeight: 1.5 }}>
            Diagnostic score reflects the current assessment. Roadmap % shows actions marked Complete.
            A positive gap means implementation is tracking ahead of the assessed baseline — expected as improvements take effect before reassessment.
          </p>
        </div>
      )}

      {/* Filters */}
      <div style={{ background: 'var(--surface)', border: '1px solid var(--line)', borderRadius: 'var(--radius)', padding: '0.85rem 1rem' }}>
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(150px, 1fr))', gap: '0.65rem', alignItems: 'end' }}>
          <div className="field-block">
            <span className="field-label">Phase</span>
            <select className="kinto-select" value={filterPhase} onChange={e => setFP(e.target.value)}>
              <option value="ALL">All phases</option>
              {PHASES.map(p => <option key={p.code} value={p.code}>{p.code} — {p.name}</option>)}
            </select>
          </div>
          <div className="field-block">
            <span className="field-label">Module</span>
            <select className="kinto-select" value={filterModule} onChange={e => setFM(e.target.value)}>
              <option value="ALL">All modules</option>
              {allModules.map(m => <option key={m.id} value={m.id}>{m.icon} {m.label}</option>)}
            </select>
          </div>
          <div className="field-block">
            <span className="field-label">Status</span>
            <select className="kinto-select" value={filterStatus} onChange={e => setFS(e.target.value)}>
              <option value="ALL">All statuses</option>
              {STATUSES.map(s => <option key={s} value={s}>{STATUS_LABELS[s]}</option>)}
            </select>
          </div>
          <div className="field-block">
            <span className="field-label">Search</span>
            <input className="kinto-input" value={searchText} onChange={e => setSearch(e.target.value)} placeholder="Action, owner, outcome…" />
          </div>
          <div style={{ display: 'flex', gap: '0.35rem', alignSelf: 'end' }}>
            <button type="button" className={`btn btn-sm ${view === 'board' ? 'btn-primary' : 'btn-secondary'}`} onClick={() => setView('board')}>Board</button>
            <button type="button" className={`btn btn-sm ${view === 'table' ? 'btn-primary' : 'btn-secondary'}`} onClick={() => setView('table')}>Table</button>
          </div>
        </div>
        {filtered.length !== items.length && (
          <p style={{ fontSize: '0.72rem', color: 'var(--muted-2)', marginTop: '0.5rem', margin: '0.5rem 0 0' }}>
            Showing {filtered.length} of {items.length} actions
            <button onClick={clearFilters} style={{ marginLeft: '0.5rem', background: 'none', border: 'none', cursor: 'pointer', color: 'var(--brand-dark)', fontSize: '0.72rem', fontWeight: 700 }}>
              Clear filters
            </button>
          </p>
        )}
      </div>

      {/* Empty state */}
      {items.length === 0 && (
        <div className="card">
          <div className="empty-state">
            <div className="empty-state-icon">🗺️</div>
            <p className="empty-state-title">No roadmap generated yet</p>
            <p className="empty-state-sub">Complete module assessments to generate the transformation roadmap. Each module produces prioritised actions that consolidate here.</p>
          </div>
        </div>
      )}

      {/* ═══ BOARD VIEW ═══════════════════════════════════════════════════════ */}
      {view === 'board' && items.length > 0 && (
        <>
          {byPhase.map(phase => {
            const phComplete = phase.items.filter(i => normStatus(i.status) === 'COMPLETE').length;
            const phPct = phase.items.length > 0 ? Math.round((phComplete / phase.items.length) * 100) : 0;
            return (
              <div key={phase.code} style={{ display: 'grid', gap: '0.75rem' }}>
                {/* Phase header */}
                <div style={{ display: 'flex', alignItems: 'center', gap: '0.75rem', paddingBottom: '0.6rem', borderBottom: '2px solid var(--line)', flexWrap: 'wrap' }}>
                  <span className={`roadmap-phase-pill ${phase.pill}`} style={{ minWidth: 34, textAlign: 'center' }}>{phase.code}</span>
                  <div style={{ flex: 1, minWidth: 160 }}>
                    <h3 style={{ margin: 0, fontSize: '0.95rem' }}>{phase.name}</h3>
                    <p style={{ margin: 0, fontSize: '0.72rem', color: 'var(--muted-2)' }}>{phase.description}</p>
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: '0.6rem', flexShrink: 0 }}>
                    <span className="text-xs muted-2">{phase.items.length} actions</span>
                    {phase.items.length > 0 && (
                      <>
                        <div className="progress-bar-shell" style={{ width: 70, height: 7 }}>
                          <div className="progress-bar-fill" style={{ width: `${phPct}%` }} />
                        </div>
                        <span style={{ fontWeight: 700, fontSize: '0.78rem', minWidth: 34 }}>{phPct}%</span>
                      </>
                    )}
                  </div>
                </div>

                {phase.items.length === 0 ? (
                  <p style={{ fontSize: '0.8rem', color: 'var(--muted-2)', fontStyle: 'italic', padding: '0.25rem 0' }}>
                    No actions match the current filters in this phase.
                  </p>
                ) : (
                  <div style={{ display: 'grid', gap: '0.65rem' }}>
                    {phase.items.map(item => (
                      <RoadmapCard
                        key={itemId(item)}
                        item={item}
                        saving={saving}
                        onSave={saveItem}
                      />
                    ))}
                  </div>
                )}
              </div>
            );
          })}
        </>
      )}

      {/* ═══ TABLE VIEW ════════════════════════════════════════════════════════ */}
      {view === 'table' && items.length > 0 && (
        <div className="card">
          <div className="table-scroll">
            <table className="kinto-table">
              <thead>
                <tr>
                  <th>Action</th>
                  <th>Phase</th>
                  <th>Module</th>
                  <th>Owner</th>
                  <th>Progress</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {filtered.map(item => {
                  const id     = itemId(item);
                  const status = normStatus(item.status);
                  const pct    = item.progress_pct ?? (status === 'COMPLETE' ? 100 : 0);
                  const mod    = modMeta(item.source_module_id || item.module_code);
                  const ph     = PHASES.find(p => p.code === (item.phase_code || 'P2'));
                  return (
                    <tr key={id}>
                      <td>
                        <div style={{ fontWeight: 600, fontSize: '0.875rem' }}>{item.initiative_title}</div>
                        {item.business_outcome && <div className="text-xs muted-2">{item.business_outcome}</div>}
                        {item.execution_notes && <div className="text-xs muted-2" style={{ fontStyle: 'italic', marginTop: '0.15rem' }}>📝 {item.execution_notes.slice(0, 80)}{item.execution_notes.length > 80 ? '…' : ''}</div>}
                      </td>
                      <td>
                        {ph && <span className={`roadmap-phase-pill ${ph.pill}`} style={{ fontSize: '0.65rem', padding: '0.15rem 0.4rem' }}>{ph.code}</span>}
                      </td>
                      <td>
                        <span style={{ fontSize: '0.78rem', fontWeight: 600, color: mod.color, whiteSpace: 'nowrap' }}>
                          {mod.icon} {mod.label}
                        </span>
                      </td>
                      <td className="text-xs muted-2">{item.owner_role || '—'}</td>
                      <td style={{ minWidth: 110 }}>
                        <div style={{ display: 'flex', alignItems: 'center', gap: '0.4rem' }}>
                          <div className="progress-bar-shell" style={{ flex: 1, height: 6 }}>
                            <div className="progress-bar-fill" style={{ width: `${pct}%` }} />
                          </div>
                          <span style={{ fontWeight: 700, fontSize: '0.75rem', minWidth: 32, textAlign: 'right' }}>{pct}%</span>
                        </div>
                      </td>
                      <td>
                        <select
                          value={status}
                          disabled={saving === id}
                          onChange={e => {
                            const next = e.target.value;
                            const autoPct = next === 'COMPLETE' ? 100 : next === 'NOT_STARTED' ? 0 : undefined;
                            void saveItem(id, { status: next, ...(autoPct !== undefined ? { progressPct: autoPct } : {}) });
                          }}
                          className={`badge ${STATUS_BADGE[status]}`}
                          style={{ cursor: 'pointer', border: 'none', fontWeight: 600, fontSize: '0.7rem', padding: '0.2rem 0.45rem', borderRadius: 999, appearance: 'none', minWidth: 90 }}
                        >
                          {STATUSES.map(s => <option key={s} value={s}>{STATUS_LABELS[s]}</option>)}
                        </select>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}
