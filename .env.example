# ══════════════════════════════════════════════════════════════════════════════
# KINTO GLOBAL — Environment Configuration Template
# Copy this file to .env.local for local development
# For staging/production: set these in your deployment platform environment
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable/anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Service role key — NEVER expose this. Server-side only.
# Used for admin DB operations (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Kinto AI — Assistant Provider Configuration ──────────────────────────────
# The in-app Kinto AI assistant supports two providers:
#   - Your own AI (OpenAI or custom endpoint) as PRIMARY
#   - Anthropic Claude as FALLBACK (only used if primary fails or is not set)
#
# Set ASSISTANT_PRIMARY_PROVIDER to activate your primary AI.
# Leave it unset to use Claude only.
#
# Option A — OpenAI (GPT-4o, GPT-4o-mini, etc.)
# Get your key from: https://platform.openai.com/api-keys
ASSISTANT_PRIMARY_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini           # or gpt-4o for higher quality
#
# Option B — Your own custom AI endpoint (must accept OpenAI-compatible SSE)
# ASSISTANT_PRIMARY_PROVIDER=custom
# ASSISTANT_CUSTOM_URL=https://your-ai-endpoint.com/v1/chat/completions
# ASSISTANT_CUSTOM_API_KEY=your-custom-key-here
#
# Option C — Anthropic Claude as primary (no own AI, Claude only)
# ASSISTANT_PRIMARY_PROVIDER=anthropic
#
# Fallback — Anthropic Claude (used when primary fails or is not configured)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6  # optional override

# ── Python Engine ─────────────────────────────────────────────────────────────
# Base URL for the FastAPI Python engine (local: http://127.0.0.1:8000)
# In production: the URL of your deployed Python service
PYTHON_API_BASE_URL=http://127.0.0.1:8000

# Python binary path for report artifact generation
# Default: python3. Override if using a venv: /app/.venv/bin/python
PYTHON_BIN=python3

# ── Application ───────────────────────────────────────────────────────────────
# Deployment environment: development | staging | production
NODE_ENV=development

# Application base URL (used for absolute URL generation in reports/emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Report artifact storage directory (relative to project root)
# In production: set to a path outside the deployment bundle
REPORT_ARTIFACTS_DIR=runtime_artifacts/reports

# ── Optional: Monitoring (Sentry) ─────────────────────────────────────────────
# Sentry DSN for error monitoring — leave blank to disable
# SENTRY_DSN=

# ── Optional: Feature flags ───────────────────────────────────────────────────
# Set to true to enable the AIUC prioritization view (Pilot Now buckets)
# NEXT_PUBLIC_ENABLE_AIUC_PRIORITIZATION=true

# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED VARIABLES SUMMARY
# ══════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_SUPABASE_URL          — required
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY — required
# SUPABASE_SERVICE_ROLE_KEY         — required (server-side only)
# PYTHON_API_BASE_URL               — required (dev: localhost:8000)
# PYTHON_BIN                        — optional (default: python3)
# NODE_ENV                          — optional (default: development)
# NEXT_PUBLIC_APP_URL               — optional (default: localhost:3000)
